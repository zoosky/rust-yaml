#!/bin/sh

# Git commit-msg hook — validates Conventional Commits via `committed` (Rust).
# Replaces the previous Node.js / npx commitlint setup.

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

if ! command -v committed >/dev/null 2>&1; then
  printf '%b❌ committed not found.%b\n' "$RED" "$NC"
  printf '%bInstall with:%b cargo install committed\n' "$YELLOW" "$NC"
  printf '%bOr (faster):%b  cargo binstall committed\n' "$YELLOW" "$NC"
  exit 1
fi

if committed --commit-file "$1"; then
  printf '%b✅ Commit message follows conventional format%b\n' "$GREEN" "$NC"
  exit 0
fi

printf '%b❌ Commit message validation failed%b\n' "$RED" "$NC"
printf '%bExpected:%b      <type>(<scope>)?!?: <description>\n' "$YELLOW" "$NC"
printf '\n'
printf '%bAllowed types:%b init, build, ci, chore, docs, feat, fix,\n' "$YELLOW" "$NC"
printf '               perf, refactor, release, revert, style, test\n'
printf '%bExample:%b       feat(parser): add support for complex mapping keys\n' "$YELLOW" "$NC"
printf '\n'
printf 'See .gitmessage and committed.toml for full rules.\n'
exit 1
